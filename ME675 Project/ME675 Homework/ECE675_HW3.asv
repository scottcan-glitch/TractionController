%[text] ![](text:image:804e)
clear all
% States
syms theta theta_dot theta_dot_dot J u
theta %[output:0aeb6bd3]
theta_dot %[output:0c8f550f]
theta_dot_dot %[output:829449c4]
StateVector = [theta; theta_dot] %[output:96ff02f7]

% Define the continuous-time state-space representation
A = [0 1; 0 0];
B = [0; 1]; %for J=1
C = eye(2);
D = zeros(2, 1);
Ts = 0.25 %[output:542771bc]
LTI_sys = ss(A,B,C,D) %[output:5233cbf1]
x0 = [pi/2; 0] %IC %[output:1fb4e4c9]
xN = [0; 0];   %TC
LTI_sys_d = c2d(LTI_sys,Ts) %Discrete System %[output:8b733507]
Ad = LTI_sys_d.A %[output:7ba717ab]
Bd = LTI_sys_d.B %[output:2d838297]
Cd = LTI_sys_d.C %[output:7d93eab0]
Dd = LTI_sys_d.D %[output:3c8ffe14]

%Cost Function f_cost
% f_cost = @(u) sum(u.^2)
Ncost=20; %optimizes cost over 20 horizon
Nterminal = 20; %for optimization with Nterminal = i, x must reach xN by i on the horizon, & stay
U_guess = rand(Ncost,1);

solver_options = optimoptions('fmincon', ...
    'Display','iter', ...
    'Algorithm','sqp', ...
    'MaxFunctionEvaluations',5e4, ...
    'TolFun',1e-9, ...
    'TolCon',1e-9);

function J = f_cost(U,Ncost)
% U is a vertically concatenated vector of control input vectors u.
% Our system is single input so ui is 1x1
% For L input system & N horizon, U has dimension LN x 1. Function
% returns cost for the series of inputs over the horizon (applies u1,
% u2, ..., uN)

J = 0;
    for k=0:Ncost-1
        u_inc = U(k+1);
        J_inc = sum(u_inc.^2);
        J = J + J_inc;
    end
end

function [c, ceq] = nonlcon(U, Ncost, Nterminal, x0, xN, Ad, Bd)
% c <= 0 & ceq == 0 are given to fmincon as constraints on the optimization
% where c & ceq are nonlinear functions of U, the optimization vector (stack of inputs)
% x_prediction moves along horizon with system dynamics to N where
% terminal constraint x(:,N) = xN defined above is set using ceq.
% This constraint is linear so it should probably not be under nonlcon
% fmincon input, but oh well

    x_prediction = [x0 zeros(2,Ncost-1)];
    for k=0:Ncost-1
        u_inc = U(k+1);
        x_prediction(:,k+2) = Ad*x_prediction(:,k+1) + Bd*u_inc;
    end

% Terminal Constraint: x_prediction(:,N) = x0, solver takes ceq = 0 as
% constraint:
number_of_xN_on_horizon = Ncost+1 - Nterminal;
vector_of_xN = zeros(2,number_of_xN_on_horizon);

% vector_of_xN = [xN, xN, xN, ... xN] with number_of_xN_on_horizon columns
for i=1:number_of_xN_on_horizon
    vector_of_xN(:,i) = xN;
end
ceq = x_prediction(:,Nterminal:Ncost)-vector_of_xN;
c=[];
end

%Anonymous cost and constraint function handles so that the solver can run
%different values of U, and the other arguments are grabbed from
%earlier in the script
f_cost_anonymous = @(U) f_cost(U,Ncost) %[output:566a372e]
nonlcon_anonymous = @(U) nonlcon(U, Ncost, Nterminal, x0, xN, Ad, Bd) %[output:7f6df947]


U_optimal1 = fmincon(f_cost_anonymous,U_guess,[],[],[],[],[],[],nonlcon_anonymous) %[output:227b90e1] %[output:6cafdea9]

% We found the optimal control sequence by fmincon sqp solver, now lets
% apply to the continuous time system and check results in phase plane

% t=0:

x_disc = [x0, zeros(2,Ncost-1)] %[output:4d2fcda6]
for k=1:Ncost-1
x_disc(:,k+1) = Ad*x_disc(:,k) + Bd*U_optimal1(k);
end

%Close the loop and run for 20 time steps to see if the MPC controller can
%achieve the desire terminal state. We will use foward euler with timestep
%Ts/50 to approximate the continuous time system, and apply ZOH, with the
%input coming from the nonlinear LQN solution (first u in U_optimal)

t=0:Ts:(Ts*Ncost) %[output:3d839a96]
x_cl = [x0, zeros(2,size(t,2)-1)] %[output:96927503]
x_next = x0;
k=0;
Nterminal=20;   %This is the prediction horizon for when the terminal constraint must be met.
                % Each time a new optimal U is calculated, N reduces by one as the terminal
                % constraint gets closer and closer in the horizon
U_optimal2 = zeros(Ncost,20) %[output:0bbf2351]

for i=1:size(t,2) %[output:group:3155fcc4]
% Uses x0 from top of script for first loop. Then uses last assigned x0
    if floor((i/Ts)+1)>k
        nonlcon_current = @(U) nonlcon(U, Ncost, Nterminal, x_next, xN, Ad, Bd);
        U_optimal2(:,k+1) = fmincon(f_cost_anonymous,U_guess,[],[],[],[],[],[],nonlcon_current) %[output:8929120f] %[output:69c554f3] %[output:1fced82e] %[output:0dd4f2a9] %[output:2270320d] %[output:39f177d9] %[output:75e5a92e] %[output:1b611e9f] %[output:19d0a3ec] %[output:95e6c54e] %[output:88f9f47c] %[output:761f209b] %[output:47b0ca96] %[output:177daaec] %[output:2816c12f] %[output:3567079e] %[output:82732518] %[output:15b8d897] %[output:3a6c80fb] %[output:75cf1edd] %[output:2e744837] %[output:7cafd3f3] %[output:7772ef59] %[output:4606112b] %[output:3133ee01] %[output:72575528] %[output:2c598e88] %[output:2f286655] %[output:4dc1533c] %[output:522e6ba2] %[output:1b651fd7] %[output:8a53381f] %[output:561fe4dc] %[output:5fbab662] %[output:1acbea9c] %[output:6a1e3475] %[output:9eee92dd] %[output:36e2ae29] %[output:4e0a0cca] %[output:4f977431] %[output:16ab0d29] %[output:2c041d11]
        k = k+1;
        Nterminal = Nterminal-1;    %Next U_optimal must be found where terminal constraint is 1 closer in its horizon
    end
x_next = Ad*x_next + B*U_optimal2(1,k);
x_cl(:,i+1) = x_next;
x0 = x_next;
end %[output:group:3155fcc4]

plot(x_disc(1,:),x_disc(2,:)) %[output:5b2b2595]
hold on %[output:5b2b2595]
scatter(x_disc(1,Ncost), x_disc(2,Ncost),'Color','r') %[output:5b2b2595]
figure; %[output:3f986dd9]
plot(x_cl(1,:),x_cl(2,:)) %[output:3f986dd9]
figure;

% plot(t,)
% Find minimizer with quadprog
% quadprog(1,0,)

